{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "accountant", "employee", "viewer"] },
        "companyId": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Organization": {
      "title": "Organization",
      "description": "Company or business entity",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "subscriptionPlan": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Income or expense record",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "companyId": { "type": "string" },
        "receiptUrl": { "type": "string" }
      },
      "required": ["amount", "type", "category", "date", "companyId"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Customer invoice",
      "type": "object",
      "properties": {
        "invoiceNumber": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "items": { "type": "array" },
        "companyId": { "type": "string" }
      },
      "required": ["invoiceNumber", "amount", "status", "dueDate", "companyId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/organizations/{orgId}": {
      "schema": "Organization",
      "description": "Organizations"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transactions"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Invoices"
    }
  }
}
