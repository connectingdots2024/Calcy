rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "connectingdotsmedia2024@gmail.com" && request.auth.token.email_verified == true));
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
      
      match /transactions/{transactionId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /invoices/{invoiceId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /clients/{clientId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /templates/{templateId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /settings/company {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /employees/{employeeId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if isAdmin();
    }
    
    match /taxJurisdictions/{jurisdictionId} {
      allow read: if isAuthenticated();
    }
  }
}
